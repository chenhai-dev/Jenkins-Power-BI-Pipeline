{
  "powershell.scriptAnalysis.enable": true,
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.useCorrectCasing": true,
  "powershell.codeFormatting.autoCorrectAliases": true,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.eol": "\n",
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "[yaml]": {
    "editor.tabSize": 2
  },
  "[bicep]": {
    "editor.tabSize": 2
  },
  "[json]": {
    "editor.tabSize": 2
  },
  "[markdown]": {
    "editor.wordWrap": "on",
    "editor.quickSuggestions": {
      "comments": "off",
      "strings": "off",
      "other": "off"
    }
  },
  "yaml.schemas": {
    "https://json.schemastore.org/github-workflow.json": [".github/workflows/*.yml", "pipelines/github-actions*.yml"],
    "https://json.schemastore.org/azure-pipelines.json": ["pipelines/azure-pipelines*.yml"]
  },
  "files.associations": {
    "*.bicepparam": "bicep-params"
  }
}
