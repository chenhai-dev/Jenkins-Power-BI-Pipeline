// =============================================================================
// Power BI Report Deployment - Jenkins Pipeline
// =============================================================================
// Declarative pipeline that promotes through Dev -> Test -> Prod with approval
// gates. Uses Jenkins Credentials binding to pull SP details + KV secrets.
//
// Requires on Jenkins:
//   - Jenkins 2.387+ with Declarative Pipeline support
//   - Azure Credentials Plugin (OR generic Secret Text credentials)
//   - Credentials Binding Plugin
//   - Pipeline: Stage View Plugin
//   - PowerShell 7.2+ installed on agents (Windows preferred, Linux works)
//   - Optional: Blue Ocean for better UI
//
// Configure in Jenkins > Manage Jenkins > Credentials (see docs/JENKINS-SETUP.md):
//   - pbi-sp-tenant-id          (Secret text)
//   - pbi-sp-dev-client-id      (Secret text)
//   - pbi-sp-dev-client-secret  (Secret text)
//   - pbi-sp-test-client-id     (Secret text)
//   - pbi-sp-test-client-secret (Secret text)
//   - pbi-sp-prod-client-id     (Secret text)
//   - pbi-sp-prod-client-secret (Secret text)
//   - az-sp-kv-reader           (Azure Service Principal — for KV access)
// =============================================================================

pipeline {
    agent {
        label 'powershell && windows'   // Pin to labeled agents with pwsh + Windows
    }

    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 2, unit: 'HOURS')
        buildDiscarder(logRotator(
            numToKeepStr: '50',
            artifactNumToKeepStr: '30',
            daysToKeepStr: '90'
        ))
        disableConcurrentBuilds()       // One deploy at a time per branch
        skipStagesAfterUnstable()
    }

    triggers {
        // Poll SCM every 5 minutes (or use webhooks — preferred)
        pollSCM('H/5 * * * *')
    }

    parameters {
        choice(
            name: 'DEPLOY_SCOPE',
            choices: ['full', 'dev-only', 'test-only', 'prod-only'],
            description: 'Scope of deployment. "full" = Dev -> Test -> Prod with gates.'
        )
        booleanParam(
            name: 'DRY_RUN',
            defaultValue: false,
            description: 'Validate only, do not publish to Power BI.'
        )
        booleanParam(
            name: 'SKIP_REFRESH',
            defaultValue: false,
            description: 'Skip triggering dataset refresh after publish.'
        )
        string(
            name: 'REPORT_FILTER',
            defaultValue: '*',
            description: 'Wildcard filter to deploy specific reports only.'
        )
    }

    environment {
        // Shared credentials
        PBI_TENANT_ID        = credentials('pbi-sp-tenant-id')

        // Pipeline-wide env
        ARTIFACT_NAME        = 'powerbi-reports'
        POWERSHELL_VERSION   = '7.4.0'
    }

    stages {
        // ---------------------------------------------------------------------
        stage('Checkout') {
            steps {
                checkout scm
                script {
                    env.GIT_COMMIT_SHORT = sh(
                        returnStdout: true,
                        script: 'git rev-parse --short HEAD'
                    ).trim()
                    currentBuild.displayName = "#${BUILD_NUMBER} • ${env.GIT_COMMIT_SHORT} • ${env.BRANCH_NAME}"
                }
            }
        }

        // ---------------------------------------------------------------------
        stage('Install dependencies') {
            steps {
                pwsh '''
                    Write-Host "PowerShell version: $($PSVersionTable.PSVersion)"
                    if ($PSVersionTable.PSVersion.Major -lt 7) {
                        throw "PowerShell 7.2+ required on agent."
                    }

                    $modules = @(
                        @{ Name = 'MicrosoftPowerBIMgmt'; MinVersion = '1.2.1111' }
                        @{ Name = 'powershell-yaml';      MinVersion = '0.4.7'    }
                        @{ Name = 'Az.KeyVault';          MinVersion = '5.0.0'    }
                        @{ Name = 'Az.Accounts';          MinVersion = '2.12.0'   }
                        @{ Name = 'Pester';               MinVersion = '5.0.0'    }
                        @{ Name = 'PSScriptAnalyzer';     MinVersion = '1.21.0'   }
                    )

                    foreach ($m in $modules) {
                        if (-not (Get-Module -ListAvailable -Name $m.Name |
                                  Where-Object { $_.Version -ge $m.MinVersion })) {
                            Write-Host "Installing $($m.Name)..."
                            Install-Module -Name $m.Name -MinimumVersion $m.MinVersion `
                                -Force -Scope CurrentUser -AcceptLicense -AllowClobber
                        }
                    }
                '''
            }
        }

        // ---------------------------------------------------------------------
        stage('Lint & unit tests') {
            parallel {
                stage('PSScriptAnalyzer') {
                    steps {
                        pwsh '''
                            Import-Module PSScriptAnalyzer
                            $issues = Invoke-ScriptAnalyzer -Path . -Recurse -Severity Error,Warning
                            if ($issues) {
                                $issues | Format-Table -AutoSize
                                if (($issues | Where-Object Severity -eq 'Error').Count -gt 0) {
                                    throw "PSScriptAnalyzer found errors."
                                }
                                Write-Warning "$($issues.Count) warnings - review before merge."
                            }
                        '''
                    }
                }

                stage('Pester') {
                    steps {
                        pwsh '''
                            Import-Module Pester -MinimumVersion 5.0
                            $cfg = New-PesterConfiguration
                            $cfg.Run.Path = './tests'
                            $cfg.Run.ExcludePath = './tests/integration'
                            $cfg.Output.Verbosity = 'Detailed'
                            $cfg.TestResult.Enabled = $true
                            $cfg.TestResult.OutputFormat = 'JUnitXml'
                            $cfg.TestResult.OutputPath = 'test-results.xml'
                            $cfg.Run.PassThru = $true
                            $result = Invoke-Pester -Configuration $cfg
                            if ($result.FailedCount -gt 0) {
                                throw "$($result.FailedCount) test(s) failed."
                            }
                        '''
                    }
                    post {
                        always {
                            junit allowEmptyResults: true, testResults: 'test-results.xml'
                        }
                    }
                }
            }
        }

        // ---------------------------------------------------------------------
        stage('Pre-deployment validation') {
            steps {
                pwsh '''
                    ./scripts/Invoke-PreDeploymentValidation.ps1 `
                        -ArtifactPath ./reports `
                        -Environment Prod `
                        -ConfigPath ./config/prod.yaml
                '''
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: 'reports/validation-results.json',
                        allowEmptyArchive: true,
                        fingerprint: true
                    )
                }
            }
        }

        // ---------------------------------------------------------------------
        stage('Package artifact') {
            steps {
                pwsh '''
                    # Snapshot everything the deploy scripts need
                    $stagingDir = "$env:WORKSPACE/staging"
                    New-Item -ItemType Directory -Path $stagingDir -Force | Out-Null

                    Copy-Item -Path ./reports    -Destination $stagingDir -Recurse -Force
                    Copy-Item -Path ./modules    -Destination $stagingDir -Recurse -Force
                    Copy-Item -Path ./scripts    -Destination $stagingDir -Recurse -Force
                    Copy-Item -Path ./config     -Destination $stagingDir -Recurse -Force

                    Compress-Archive -Path "$stagingDir/*" `
                        -DestinationPath "$env:WORKSPACE/powerbi-reports.zip" `
                        -Force
                '''
                archiveArtifacts(
                    artifacts: 'powerbi-reports.zip',
                    fingerprint: true,
                    onlyIfSuccessful: true
                )
            }
        }

        // ---------------------------------------------------------------------
        stage('Deploy to Dev') {
            when {
                anyOf {
                    expression { params.DEPLOY_SCOPE == 'full' }
                    expression { params.DEPLOY_SCOPE == 'dev-only' }
                }
                not { changeRequest() }     // Skip for PRs (build only)
            }
            environment {
                PBI_CLIENT_ID     = credentials('pbi-sp-dev-client-id')
                PBI_CLIENT_SECRET = credentials('pbi-sp-dev-client-secret')
            }
            steps {
                script {
                    deployToEnvironment('Dev')
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: 'reports/deployment-summary.json',
                        allowEmptyArchive: true
                    )
                }
            }
        }

        // ---------------------------------------------------------------------
        stage('Approval: Deploy to Test') {
            when {
                anyOf {
                    expression { params.DEPLOY_SCOPE == 'full' }
                    expression { params.DEPLOY_SCOPE == 'test-only' }
                }
                not { changeRequest() }
            }
            options {
                timeout(time: 4, unit: 'HOURS')
            }
            steps {
                script {
                    def approver = input(
                        message: 'Approve deployment to TEST?',
                        ok: 'Approve',
                        submitter: 'qa-leads,data-platform-leads',
                        submitterParameter: 'APPROVER'
                    )
                    env.TEST_APPROVER = approver
                    echo "Test deployment approved by: ${approver}"
                }
            }
        }

        stage('Deploy to Test') {
            when {
                anyOf {
                    expression { params.DEPLOY_SCOPE == 'full' }
                    expression { params.DEPLOY_SCOPE == 'test-only' }
                }
                not { changeRequest() }
            }
            environment {
                PBI_CLIENT_ID     = credentials('pbi-sp-test-client-id')
                PBI_CLIENT_SECRET = credentials('pbi-sp-test-client-secret')
            }
            steps {
                script {
                    deployToEnvironment('Test')
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: 'reports/deployment-summary.json',
                        allowEmptyArchive: true
                    )
                }
            }
        }

        // ---------------------------------------------------------------------
        stage('Approval: Deploy to Prod') {
            when {
                anyOf {
                    expression { params.DEPLOY_SCOPE == 'full' }
                    expression { params.DEPLOY_SCOPE == 'prod-only' }
                }
                anyOf {
                    branch 'main'
                    branch pattern: 'release/.*', comparator: 'REGEXP'
                }
            }
            options {
                timeout(time: 8, unit: 'HOURS')
            }
            steps {
                script {
                    // Enforce business-hours restriction
                    def now = new Date()
                    def cal = Calendar.instance
                    cal.time = now
                    def dow = cal.get(Calendar.DAY_OF_WEEK)
                    def hour = cal.get(Calendar.HOUR_OF_DAY)
                    def isBusinessHours = (dow in [Calendar.MONDAY..Calendar.THURSDAY]) &&
                                          (hour >= 8 && hour < 17)

                    if (!isBusinessHours && !params.DRY_RUN) {
                        def proceed = input(
                            message: "Deployment is outside business hours (Mon-Thu 08:00-17:00). " +
                                     "Emergency hotfix requires CAB lead approval.",
                            ok: 'Proceed (emergency)',
                            submitter: 'cab-leads',
                            submitterParameter: 'CAB_APPROVER'
                        )
                        env.CAB_APPROVER = proceed
                    }

                    def approver = input(
                        message: "Approve deployment to PRODUCTION?\n" +
                                 "Build: ${env.BUILD_NUMBER}\n" +
                                 "Commit: ${env.GIT_COMMIT_SHORT}\n" +
                                 "Branch: ${env.BRANCH_NAME}",
                        ok: 'Approve',
                        submitter: 'data-platform-leads,release-managers',
                        submitterParameter: 'PROD_APPROVER'
                    )
                    env.PROD_APPROVER = approver
                    echo "Prod deployment approved by: ${approver}"
                }
            }
        }

        stage('Deploy to Prod') {
            when {
                anyOf {
                    expression { params.DEPLOY_SCOPE == 'full' }
                    expression { params.DEPLOY_SCOPE == 'prod-only' }
                }
                anyOf {
                    branch 'main'
                    branch pattern: 'release/.*', comparator: 'REGEXP'
                }
            }
            environment {
                PBI_CLIENT_ID     = credentials('pbi-sp-prod-client-id')
                PBI_CLIENT_SECRET = credentials('pbi-sp-prod-client-secret')
            }
            steps {
                script {
                    deployToEnvironment('Prod')
                }
            }
            post {
                always {
                    archiveArtifacts(
                        artifacts: 'reports/deployment-summary.json',
                        allowEmptyArchive: true
                    )
                }
                success {
                    // Tag the commit that made it to Prod
                    sshagent(credentials: ['jenkins-git-deploy-key']) {
                        sh """
                            git tag prod-\${BUILD_NUMBER}-\${GIT_COMMIT_SHORT}
                            git push origin prod-\${BUILD_NUMBER}-\${GIT_COMMIT_SHORT} || true
                        """
                    }
                }
            }
        }
    }

    post {
        success {
            echo "✓ Pipeline succeeded"
            script {
                if (env.BRANCH_NAME == 'main') {
                    notifySlack(
                        color: 'good',
                        message: "✓ Power BI deploy succeeded: build ${env.BUILD_NUMBER}"
                    )
                }
            }
        }
        failure {
            echo "✗ Pipeline failed"
            notifySlack(
                color: 'danger',
                message: "✗ Power BI deploy FAILED: build ${env.BUILD_NUMBER}\n" +
                         "${env.BUILD_URL}"
            )
            // Auto-open a ticket (customize for your ITSM)
            // createIncident(...)
        }
        unstable {
            notifySlack(
                color: 'warning',
                message: "⚠ Power BI deploy UNSTABLE: build ${env.BUILD_NUMBER}"
            )
        }
        always {
            // Clean workspace EXCEPT cached modules
            cleanWs(
                patterns: [
                    [pattern: 'staging/', type: 'INCLUDE'],
                    [pattern: 'powerbi-reports.zip', type: 'INCLUDE'],
                    [pattern: '**/*.log', type: 'INCLUDE']
                ]
            )
        }
    }
}

// =============================================================================
// Helper functions
// =============================================================================

def deployToEnvironment(String envName) {
    def configPath = "./config/${envName.toLowerCase()}.yaml"
    def dryRun = params.DRY_RUN ? '-DryRun' : ''
    def skipRefresh = params.SKIP_REFRESH ? '-SkipRefresh' : ''
    def reportFilter = params.REPORT_FILTER ?: '*'

    withEnv([
        "PBI_ENV=${envName}",
        "PBI_CONFIG=${configPath}"
    ]) {
        pwsh """
            \$env:PBI_CLIENT_ID     = '${env.PBI_CLIENT_ID}'
            \$env:PBI_CLIENT_SECRET = '${env.PBI_CLIENT_SECRET}'
            \$env:PBI_TENANT_ID     = '${env.PBI_TENANT_ID}'

            # Authenticate to Azure (for Key Vault access)
            # Uses the Azure credentials injected by withCredentials
            Connect-AzAccount -ServicePrincipal `
                -Credential (New-Object PSCredential(
                    \$env:PBI_CLIENT_ID,
                    (ConvertTo-SecureString \$env:PBI_CLIENT_SECRET -AsPlainText -Force)
                )) `
                -TenantId \$env:PBI_TENANT_ID | Out-Null

            ./scripts/Deploy-PowerBIReport.ps1 `
                -Environment ${envName} `
                -ConfigPath ${configPath} `
                -ArtifactPath ./reports `
                -ReportFilter '${reportFilter}' `
                ${dryRun} `
                ${skipRefresh}
        """
    }
}

def notifySlack(Map args) {
    try {
        slackSend(
            channel: '#data-platform-announce',
            color: args.color,
            message: args.message,
            teamDomain: 'yourorg',
            tokenCredentialId: 'slack-notifier-token'
        )
    } catch (Exception e) {
        echo "Slack notification failed (non-fatal): ${e.message}"
    }
}
